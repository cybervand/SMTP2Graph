# Host IP to bind the published ports to.
# Use 127.0.0.1 for local-only access, or set your server's LAN IP for network access.
SMTP2GRAPH_BIND_IP=127.0.0.1
SMTP2GRAPH_SMTP_PORT=587
SMTP2GRAPH_ADMIN_PORT=16666
SMTP2GRAPH_ADMIN_INTERNAL_PORT=16666

# Host directory that stores smtp2graph config and queue data.
SMTP2GRAPH_DATA_PATH=./plugin-ui/data

# Host directory that contains your TLS certificate and private key files.
# Example: /etc/letsencrypt or /etc/letsencrypt/live/sens.no
SMTP2GRAPH_CERTS_HOST_PATH=/etc/letsencrypt

# Where that directory should appear inside the containers.
# Use this base path in the admin UI when entering tlsCertPath and tlsKeyPath.
SMTP2GRAPH_CERTS_CONTAINER_PATH=/certs

SMTP2GRAPH_CONTAINER_NAME=smtp2graph
SMTP2GRAPH_ADMIN_CONTAINER_NAME=smtp2graph-admin
SMTP2GRAPH_CONTAINER_IP=172.30.50.10
SMTP2GRAPH_ADMIN_CONTAINER_IP=172.30.50.11
SMTP2GRAPH_DOCKER_SUBNET=172.30.50.0/24

SMTP2GRAPH_ADMIN_USERNAME=admin
SMTP2GRAPH_ADMIN_PASSWORD_HASH_FILE=/config/admin-password.hash
SMTP2GRAPH_ADMIN_CONFIG_PATH=/config/config.yml
SMTP2GRAPH_ADMIN_SECURE_COOKIES=true

# No passwords or secret keys belong in this file.
# Keep your admin password hash in the config volume at the path above.
